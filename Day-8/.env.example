# ================================
# ENVIRONMENT VARIABLES TEMPLATE
# ================================
# Copy this file to .env and fill in your actual values
# ⚠️ CRITICAL: NEVER commit .env to version control!
# .env is already in .gitignore - verify it's not tracked: git status

# ================================
# APPLICATION ENVIRONMENT
# ================================
# Options: development, test, production
# Use 'production' for strict validation
ENV=development

# ================================
# SECRET KEY CONFIGURATION
# ================================
# Generate a unique SECRET_KEY for JWT and session encryption
# Command: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Requirements:
#   - Minimum 32 characters
#   - Cryptographically random
#   - Different for each environment (dev/staging/prod)
#   - Never hardcoded in source
#   - Never shared or publicly exposed
SECRET_KEY=GENERATE_UNIQUE_KEY_USING_COMMAND_ABOVE_AT_LEAST_32_CHARS

# ================================
# JWT CONFIGURATION
# ================================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ================================
# APPLICATION URL
# ================================
# IMPORTANT: This must match EXACTLY what's registered in OAuth provider!
# Mismatch = redirect_uri_mismatch error
# Use 'localhost' NOT '127.0.0.1' (they are different)
# Examples:
#   - Local dev: http://localhost:8000
#   - Production: https://yourdomain.com
APP_BASE_URL=http://localhost:8000

# ================================
# GOOGLE OAUTH CREDENTIALS
# ================================
# ⚠️ HIGHLY SENSITIVE - Keep absolutely secure!
# Source: https://console.cloud.google.com/apis/credentials
# How to get:
#   1. Create Google Cloud project
#   2. Enable OAuth 2.0
#   3. Create OAuth 2.0 Client ID (Web application)
#   4. Add authorized redirect URI matching APP_BASE_URL/auth/callback/google
#   5. Copy credentials here
# Security:
#   - Never share these values
#   - Create separate credentials per environment
#   - Rotate credentials regularly (monthly recommended)
#   - Monitor for unauthorized use in Google Cloud Console
GOOGLE_CLIENT_ID=YOUR_ACTUAL_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_ACTUAL_GOOGLE_CLIENT_SECRET_HERE

# ================================
# GITHUB OAUTH (OPTIONAL)
# ================================
GITHUB_CLIENT_ID=your_github_client_id_if_using
GITHUB_CLIENT_SECRET=your_github_client_secret_if_using

# ================================
# SECURITY CHECKLIST
# ================================
# Before running the application, verify:
#
# Code & Configuration:
#   [ ] No hardcoded secrets in any Python files
#   [ ] .env file is in .gitignore (git check-ignore .env)
#   [ ] No secrets in git history (git log -p .env)
#   [ ] All environment variables loaded from .env
#
# Secret Generation & Security:
#   [ ] SECRET_KEY is generated using secrets.token_urlsafe(32)
#   [ ] SECRET_KEY is at least 32 characters
#   [ ] SECRET_KEY is different for dev/staging/production
#   [ ] No test/default values left in production
#
# OAuth Configuration:
#   [ ] GOOGLE_CLIENT_ID is from correct Google Cloud project
#   [ ] GOOGLE_CLIENT_SECRET is correctly copied (no typos)
#   [ ] Redirect URI in Google Console matches APP_BASE_URL/auth/callback/google
#   [ ] APP_BASE_URL uses http:// for local, https:// for production
#   [ ] Using localhost NOT 127.0.0.1 (or vice versa consistently)
#
# File Permissions & Storage:
#   [ ] .env file has restricted permissions (chmod 600 on Unix)
#   [ ] .env is not readable by other users
#   [ ] .env is stored in secure location on server
#   [ ] Production .env is in secure vault, not on filesystem
#
# Regular Maintenance:
#   [ ] OAuth credentials rotated monthly
#   [ ] No old/invalid credentials in .env
#   [ ] SECRET_KEY rotated yearly or after personnel changes
#   [ ] Access logs checked for unauthorized attempts
#   [ ] Unused OAuth credentials deleted from Google Console

# ================================
# SETUP INSTRUCTIONS
# ================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Generate SECRET_KEY:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 3. Get Google OAuth credentials:
#    https://console.cloud.google.com/apis/credentials
#
# 4. Update .env with actual values:
#    nano .env  (or your preferred editor)
#
# 5. Verify .env is in .gitignore:
#    git check-ignore .env  (should return .env)
#
# 6. Start the application:
#    uvicorn app.main:app --reload
