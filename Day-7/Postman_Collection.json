		{
			"name": "Protected Routes - User",
			"item": [
				{
					"name": "Get Current User Profile",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer YOUR_ACCESS_TOKEN",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://127.0.0.1:8000/users/me",
							"protocol": "http",
							"host": [
								"127",
								"0",
								"0",
								"1"
							],
							"port": "8000",
							"path": [
								"users",
								"me"
							]
						},
						"description": "Get current logged-in user profile. Replace YOUR_ACCESS_TOKEN with token from login."
					},
					"response": []
				}
			],
			"description": "User endpoints accessible to any authenticated user"
