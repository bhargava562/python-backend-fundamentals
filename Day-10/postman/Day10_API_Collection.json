{
  "info": {
    "_postman_id": "day10-api-testing",
    "name": "Day 10: Debugging & API Testing",
    "description": "Complete API testing collection for FastAPI backend with debugging, logging, and performance testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "variable": [
      {
        "key": "base_url",
        "value": "http://localhost:8000",
        "type": "string"
      },
      {
        "key": "user_id",
        "value": "1",
        "type": "string"
      },
      {
        "key": "product_id",
        "value": "1",
        "type": "string"
      },
      {
        "key": "order_id",
        "value": "1",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Debug & Health",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has status field', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.equal('healthy');",
                  "});",
                  "",
                  "pm.test('Response time is less than 200ms', function() {",
                  "    pm.expect(pm.response.responseTime).to.be.below(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/debug/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "debug",
                "health"
              ]
            },
            "description": "Check if API is running"
          },
          "response": []
        },
        {
          "name": "Success Endpoint",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains success message', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('working');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/debug/success",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "debug",
                "success"
              ]
            },
            "description": "Test successful endpoint"
          },
          "response": []
        },
        {
          "name": "Debug Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/debug/debug-info",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "debug",
                "debug-info"
              ]
            },
            "description": "Get debug information about the API"
          },
          "response": []
        },
        {
          "name": "Performance Test (1s)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Actual duration is approximately 1 second', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.actual_duration).to.be.within(0.9, 1.2);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/debug/performance/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "debug",
                "performance",
                "1"
              ]
            },
            "description": "Test performance for 1 second"
          },
          "response": []
        },
        {
          "name": "Slow Endpoint",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time is greater than 2 seconds', function() {",
                  "    pm.expect(pm.response.responseTime).to.be.above(2000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/debug/slow",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "debug",
                "slow"
              ]
            },
            "description": "Simulates a slow endpoint (2.5 seconds)"
          },
          "response": []
        },
        {
          "name": "Intentional Error",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 500', function() {",
                  "    pm.response.to.have.status(500);",
                  "});",
                  "",
                  "pm.test('Response contains error details', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.detail).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/debug/intentional-error",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "debug",
                "intentional-error"
              ]
            },
            "description": "Triggers an intentional error for testing error handling"
          },
          "response": []
        }
      ]
