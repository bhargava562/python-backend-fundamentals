							"mode": "raw",
							"raw": "{\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"mysecretpassword\",\n  \"role\": \"user\"\n}"
						},
						"url": {
							"raw": "http://127.0.0.1:8000/auth/register",
							"protocol": "http",
							"host": [
								"127",
								"0",
								"0",
								"1"
							],
							"port": "8000",
							"path": [
								"auth",
								"register"
							]
						},
						"description": "Register a new normal user with hashed password"
					},
					"response": []
